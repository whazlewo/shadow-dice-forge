# Copy this file to .env.development (for local dev) and .env.production (for prod builds)
# Never commit .env, .env.development, or .env.production to source control

VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"
# VITE_SUPABASE_PROJECT_ID="<your-project-ref>"   # Optional, used by Lovable dev env
